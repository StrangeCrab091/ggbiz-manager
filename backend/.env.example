# ╔══════════════════════════════════════════════════════════════╗
# ║            MapManager — Cấu hình biến môi trường            ║
# ║  Sao chép file này thành .env rồi điền giá trị của bạn      ║
# ║        cp .env.example .env  (hoặc copy thủ công)           ║
# ╚══════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────
# [1] CẤU HÌNH ỨNG DỤNG
# ─────────────────────────────────────────
PORT=5000
NODE_ENV=development

# URL của Frontend (dùng cho CORS). Khi chạy local để nguyên.
FRONTEND_URL=http://localhost:5173

# Secret cho Webhook endpoint (đặt chuỗi bất kỳ, ví dụ: openssl rand -hex 32)
WEBHOOK_SECRET=your_random_webhook_secret_here


# ─────────────────────────────────────────
# [2] DATABASE — MongoDB
# ─────────────────────────────────────────
# Cách A — MongoDB Atlas (cloud, khuyến nghị):
#   1. Đăng ký miễn phí tại https://www.mongodb.com/atlas
#   2. Tạo cluster → Database Access → tạo user/password
#   3. Network Access → thêm IP của bạn (hoặc 0.0.0.0/0 để test)
#   4. Connect → Drivers → copy URI dạng mongodb+srv://...
#
# Cách B — MongoDB local:
#   URI = mongodb://localhost:27017/mapmanager
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/mapmanager?appName=mapmanager


# ─────────────────────────────────────────
# [3] GOOGLE OAUTH 2.0 & BUSINESS PROFILE API
# ─────────────────────────────────────────
# MapManager dùng 2 loại credential Google khác nhau:
#   • OAuth 2.0 Client  → để người dùng đăng nhập Google và cấp quyền quản lý Business Profile
#   • API Key           → để gọi Places API (tính năng quét đối thủ cạnh tranh)
#
# ── BƯỚC 1: Tạo Google Cloud Project ────────────────────────────
#   Truy cập: https://console.cloud.google.com/
#   → New Project → đặt tên tùy ý → Create
#
# ── BƯỚC 2: Bật các API cần thiết ───────────────────────────────
#   Menu trái → APIs & Services → Library → tìm và bật từng API:
#     ✅ Business Profile API
#     ✅ My Business Business Information API
#     ✅ Places API  (hoặc "Places API (New)")
#     ✅ Maps JavaScript API  (nếu dùng bản đồ trực quan)
#
# ── BƯỚC 3: Tạo OAuth 2.0 Client ID ────────────────────────────
#   APIs & Services → Credentials → Create Credentials → OAuth client ID
#     • Application type: Web application
#     • Name: MapManager Local (hoặc tùy ý)
#     • Authorized redirect URIs: thêm URI bên dưới
#         - Khi chạy local:      http://localhost:5000/api/auth/google/callback
#         - Khi deploy lên VPS:  https://api.yourdomain.com/api/auth/google/callback
#   → Create → copy Client ID và Client Secret vào bên dưới
#
# ── BƯỚC 4: Cấu hình OAuth Consent Screen (nếu lần đầu) ────────
#   APIs & Services → OAuth consent screen
#     • User Type: External → Create
#     • Điền App name, User support email, Developer contact
#     • Scopes: thêm "https://www.googleapis.com/auth/business.manage"
#     • Test users: thêm email Google Business của bạn
#   (Không cần publish app, chạy ở chế độ Testing là đủ)
#
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# ── BƯỚC 5: Tạo API Key (cho Places API / quét đối thủ) ─────────
#   APIs & Services → Credentials → Create Credentials → API key
#   (Khuyến nghị: Restrict key → API restrictions → chỉ cho phép Places API)
#
GOOGLE_API_KEY=your_google_maps_api_key


# ─────────────────────────────────────────
# [4] GEMINI AI — Sinh phản hồi tự động
# ─────────────────────────────────────────
# Lấy API key miễn phí tại: https://aistudio.google.com/apikey
#   → Get API key → Create API key in new project → Copy
#
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here


# ─────────────────────────────────────────
# [5] TELEGRAM BOT — Cảnh báo review tiêu cực
# ─────────────────────────────────────────
# Bước 1 — Tạo Bot:
#   Mở Telegram → tìm @BotFather → gõ /newbot
#   → Đặt tên bot → Đặt username (phải kết thúc bằng "bot")
#   → Copy token dạng: 1234567890:AABBCCDDEEFFaabbccddeeffGGHH
#
# Bước 2 — Lấy Chat ID:
#   Cách nhanh nhất:
#     1. Thêm bot vào group hoặc nhắn tin trực tiếp với bot
#     2. Truy cập: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#     3. Tìm trường "chat" → "id" trong kết quả JSON
#   Chat ID cá nhân: số nguyên dương (ví dụ: 123456789)
#   Chat ID nhóm:    số nguyên âm  (ví dụ: -987654321)
#
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeffGGHHIIJJ
TELEGRAM_CHAT_ID=123456789
